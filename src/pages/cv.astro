---
import { contact, education, experience, focusAreas, skills } from "../data/cv";
import Base from "../layouts/Base.astro";
---

<Base title="CV" description="Max Lindqvist — PLM, product master data, data engineering, automation, and AI workflows.">
  <article class="cv-article">
    <!-- Header -->
    <header class="mb-6">
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
        <img
          src={contact.image}
          alt={contact.name}
          class="h-18 w-18 rounded-full object-cover"
        />
        <div class="flex-1">
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-2xl font-bold tracking-tight">{contact.name}</h1>
            </div>
            <button
              id="download-pdf"
              type="button"
              class="print:hidden hidden cursor-pointer rounded-md border border-(--border) px-4 py-1.5 text-sm no-underline transition-colors hover:bg-(--surface) sm:inline-block"
            >
              Download PDF
            </button>
          </div>
          <div class="mt-1.5 flex flex-wrap gap-x-4 gap-y-1 text-sm text-(--muted)">
            <span>{contact.location}</span>
            <a href={contact.linkedin}>linkedin.com/in/m44</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Profile -->
    <section id="profile" class="mb-5">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Profile
      </h2>
      <p class="text-sm leading-relaxed">{contact.summary}</p>
    </section>

    <!-- Focus Areas -->
    <section id="focus" class="mb-5">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Focus Areas
      </h2>
      <ul class="space-y-0.5 text-sm">
        {focusAreas.map((area) => (
          <li class="flex gap-2">
            <span class="text-(--muted)">-</span>
            <span>{area}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Skills -->
    <section class="mb-5">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Skills
      </h2>
      <div class="grid grid-cols-1 gap-x-6 gap-y-1 sm:grid-cols-2">
        {skills.map((skill) => (
          <div class="flex items-center justify-between gap-4 text-sm">
            <span>{skill.name}</span>
            <span class="shrink-0 rounded-full border border-(--border) px-2 py-0.5 font-mono text-xs text-(--muted)">
              {skill.level}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- Work Experience -->
    <section id="experience" class="mb-5">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Work Experience
      </h2>
      <div class="space-y-3">
        {experience.map((job) => (
          <div class="border-l-2 border-(--border) pl-4">
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-semibold">{job.title}</h3>
              <span class="shrink-0 text-sm text-(--muted)">{job.period}</span>
            </div>
            <p class="text-sm text-(--muted)">{job.company}</p>
            <ul class="mt-1.5 space-y-0.5 text-sm">
              {job.points.map((point) => (
                <li class="flex gap-2">
                  <span class="text-(--muted)">-</span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section id="education">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Education
      </h2>
      {education.map((edu) => (
        <div class="border-l-2 border-(--border) pl-4">
          <h3 class="font-semibold">{edu.degree}</h3>
          <p class="text-sm text-(--muted)">{edu.institution}</p>
          {edu.note && <p class="mt-0.5 text-sm text-(--muted)">{edu.note}</p>}
        </div>
      ))}
    </section>
  </article>

  <!-- PDF Download Script -->
  <script>
    document.addEventListener("astro:page-load", () => {
      document.getElementById("download-pdf")?.addEventListener("click", () => {
        const title = document.title;
        document.title = " ";
        window.print();
        window.setTimeout(() => {
          document.title = title;
        }, 500);
      });
    });
  </script>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": contact.name,
    "jobTitle": contact.headline,
    "description": contact.summary,
    "url": contact.website,
    "image": `${contact.website}${contact.image}`,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockholm",
      "addressCountry": "SE",
    },
    "sameAs": [contact.linkedin],
    "worksFor": {
      "@type": "Organization",
      "name": "New Wave Group",
    },
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Colorado Mesa University",
    },
    "knowsAbout": ["Centric PLM", "Product Master Data", "Data Governance", "Data Engineering", "AI Engineering", "Digital Product Passport", "Traceability", "EU Compliance"],
  })} />
</Base>
