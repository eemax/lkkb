---
import {
  contact,
  education,
  experience,
  focusAreas,
  languages,
  skills,
} from "../data/cv";
import Base from "../layouts/Base.astro";
---

<Base title="CV" description="Max Lindqvist — Business Consultant specializing in Centric PLM, AI, and digital transformation.">
  <article class="cv-article">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-col items-center gap-5 sm:flex-row sm:items-start">
        <img
          src={contact.image}
          alt={contact.name}
          class="h-20 w-20 rounded-full object-cover"
        />
        <div class="flex-1">
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-2xl font-bold tracking-tight">{contact.name}</h1>
              <p class="mt-0.5 text-(--muted)">{contact.title}</p>
            </div>
            <button
              id="download-pdf"
              type="button"
              class="print:hidden hidden cursor-pointer rounded-md border border-(--border) px-4 py-1.5 text-sm no-underline transition-colors hover:bg-(--surface) sm:inline-block"
            >
              Download PDF
            </button>
          </div>
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm text-(--muted)">
            <span>{contact.email}</span>
            <span>{contact.location}</span>
            <a href={contact.website}>lkkb.se</a>
            <a href={contact.linkedin}>linkedin.com/in/m44</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Focus Areas -->
    <section id="focus" class="mb-6">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Focus Areas
      </h2>
      <ul class="space-y-0.5 text-sm">
        {focusAreas.map((area) => (
          <li class="flex gap-2">
            <span class="text-(--muted)">-</span>
            <span>{area}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Skills & Languages (side by side) -->
    <section class="mb-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div>
        <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
          Skills
        </h2>
        <div class="space-y-1">
          {skills.map((skill) => (
            <div class="flex items-center justify-between text-sm">
              <span>{skill.name}</span>
              <span class="rounded-full border border-(--border) px-2 py-0.5 font-mono text-xs text-(--muted)">
                {skill.level}
              </span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
          Languages
        </h2>
        <div class="space-y-1 text-sm">
          {languages.map((lang) => (
            <div>
              <span class="font-medium">{lang.name}</span>
              <span class="text-(--muted)"> — {lang.proficiency}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Work Experience -->
    <section id="experience" class="mb-6">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Work Experience
      </h2>
      <div class="space-y-4">
        {experience.map((job) => (
          <div class="border-l-2 border-(--border) pl-4">
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-semibold">{job.title}</h3>
              <span class="shrink-0 text-sm text-(--muted)">{job.period}</span>
            </div>
            <p class="text-sm text-(--muted)">{job.company}</p>
            <ul class="mt-1.5 space-y-0.5 text-sm">
              {job.points.map((point) => (
                <li class="flex gap-2">
                  <span class="text-(--muted)">-</span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section id="education">
      <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
        Education
      </h2>
      {education.map((edu) => (
        <div class="border-l-2 border-(--border) pl-4">
          <div class="flex items-baseline justify-between gap-4">
            <h3 class="font-semibold">{edu.degree}</h3>
            <span class="shrink-0 text-sm text-(--muted)">{edu.year}</span>
          </div>
          <p class="text-sm text-(--muted)">{edu.institution}</p>
          {edu.note && <p class="mt-0.5 text-sm text-(--muted)">{edu.note}</p>}
        </div>
      ))}
    </section>
  </article>

  <!-- PDF Download Script -->
  <script>
    document.addEventListener("astro:page-load", () => {
      document.getElementById("download-pdf")?.addEventListener("click", () => {
        window.print();
      });
    });
  </script>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": contact.name,
    "jobTitle": contact.title,
    "url": contact.website,
    "email": `mailto:${contact.email}`,
    "image": `${contact.website}${contact.image}`,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockholm",
      "addressCountry": "SE",
    },
    "sameAs": [contact.linkedin],
    "worksFor": {
      "@type": "Organization",
      "name": "Lindqvist Konsult",
      "url": contact.website,
    },
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Colorado Mesa University",
    },
    "knowsAbout": ["Centric PLM", "Master Data", "AI", "Digital Product Passport", "EU Compliance"],
  })} />
</Base>
