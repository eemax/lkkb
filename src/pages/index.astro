---
import ServiceCard from "../components/ServiceCard.astro";
import { contact } from "../data/cv";
import { services } from "../data/services";
import Base from "../layouts/Base.astro";
---

<Base title="Max Lindqvist">
  <!-- Hero -->
  <section class="mb-16 animate-fade-in">
    <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
      Working with data, systems, and software with AI leverage.
    </h1>
    <p class="mt-5 max-w-2xl text-base leading-relaxed text-(--muted)">
      Open to hands-on roles and contract projects where messy data, internal tools, integrations, automation, or existing codebases need someone who can learn fast, build carefully, and use AI well without making the work weird.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="#services"
        class="inline-block rounded-md border border-(--fg) bg-(--fg) px-5 py-2 text-sm text-(--bg) no-underline transition-colors hover:bg-transparent hover:text-(--fg)"
      >
        See What I Do
      </a>
      <a
        href="#contact"
        class="inline-block rounded-md border border-(--border) px-5 py-2 text-sm no-underline transition-colors hover:bg-(--surface)"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <!-- Positioning -->
  <section class="mb-16">
    <h2 class="mb-6 font-mono text-sm font-semibold uppercase tracking-wider text-(--muted)">
      What I Am Useful For
    </h2>
    <div class="space-y-4 text-sm leading-relaxed">
      <p>
        I work well in the layer between business data, software, and execution: APIs, structured data, validation logic, system mapping, AI workflows, and the practical glue that makes tools talk to each other.
      </p>
      <p>
        My background is product-heavy, with deep experience in PLM, product master data, traceability, compliance, and Digital Product Passports. The direction now is broader: working with data and building useful software with Python, APIs, automation, AI agents, and AI-assisted development across different stacks and project types.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="mb-16">
    <h2 class="mb-6 font-mono text-sm font-semibold uppercase tracking-wider text-(--muted)">
      Services
    </h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <h2 class="mb-6 font-mono text-sm font-semibold uppercase tracking-wider text-(--muted)">
      Get in Touch
    </h2>
    <div class="rounded-lg border border-(--border) p-6">
      <p class="leading-relaxed">
        Hiring for a role or project around data, software, integrations, automation, or product systems? Send a short note about the project, stack, and where things are stuck.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={contact.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-md border border-(--fg) bg-(--fg) px-5 py-2 text-sm text-(--bg) no-underline transition-colors hover:bg-transparent hover:text-(--fg)"
        >
          LinkedIn
        </a>
        <span class="inline-block rounded-md border border-(--border) px-5 py-2 text-sm text-(--muted)">
          {contact.emailDisplay}
        </span>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": contact.name,
    "url": contact.website,
    "description": "Available for work with data, software development with AI leverage, automation, integrations, and product systems.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockholm",
      "addressCountry": "SE",
    },
    "sameAs": [contact.linkedin],
    "knowsAbout": services.map((s) => s.name),
  })} />
</Base>
