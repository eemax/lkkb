---
interface Props {
  name: string;
  tagline: string;
  description: string;
  features: string[];
  tags: string[];
}

const { name, tagline, description, features, tags } = Astro.props;
---

<div class="rounded-lg border border-(--border) p-5 transition-colors hover:bg-(--surface)">
  <h3 class="font-semibold tracking-tight">
    {name}
  </h3>
  <p class="mt-1 text-xs text-(--muted) italic">{tagline}</p>
  <p class="mt-3 text-sm leading-relaxed">{description}</p>
  {features.length > 0 && (
    <ul class="mt-3 space-y-1 text-sm text-(--muted)">
      {features.map((feature) => (
        <li class="flex gap-2">
          <span class="text-(--muted)">-</span>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="rounded-full border border-(--border) px-2 py-0.5 font-mono text-xs text-(--muted)">
          {tag}
        </span>
      ))}
    </div>
  )}
  <a
    href={`mailto:max.lindqvist@me.com?subject=Inquiry: ${name}`}
    class="mt-4 inline-block text-sm text-(--muted) no-underline transition-colors hover:text-(--fg)"
  >
    Inquire &rarr;
  </a>
</div>
