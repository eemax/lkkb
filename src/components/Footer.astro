---
import { contact } from "../data/cv";
---

<footer class="border-t border-(--border) py-10">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-4 px-6 text-sm text-(--muted)">
    <div class="flex gap-6">
      <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-(--fg)">
        LinkedIn
      </a>
      <span>{contact.emailDisplay}</span>
    </div>
  </div>
</footer>
